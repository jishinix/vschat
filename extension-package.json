{
  "name": "vschat",
  "displayName": "Visual Studio Chat",
  "description": "",
  "version": "1.6.1",
  "engines": {
    "vscode": "^1.115.0"
  },
  "extensionKind": [
    "ui"
  ],
  "config": {
    "authDomain": "http://localhost:7010",
    "wsDomain": "http://localhost:7011"
  },
  "author": {
    "name": "Jishinix"
  },
  "publisher": "jishinix",
  "repository": {
    "type": "git",
    "url": "https://github.com/jishinix/vschat"
  },
  "categories": [
    "Other"
  ],
  "activationEvents": [
    "onView:vschat-sidebar"
  ],
  "files": [
    "./**/*"
  ],
  "main": "./extension.js",
  "contributes": {
    "viewsContainers": {
      "activitybar": [
        {
          "id": "vschat-sidebar-container",
          "title": "Visual Studio Chat",
          "icon": "resources/chat-icon.svg"
        }
      ]
    },
    "views": {
      "vschat-sidebar-container": [
        {
          "type": "webview",
          "id": "vschat-sidebar",
          "name": "Chat",
          "icon": "resources/chat-icon.svg"
        }
      ]
    },
    "commands": [
      {
        "command": "extension.helloWorld",
        "title": "Hello World"
      }
    ]
  }
}