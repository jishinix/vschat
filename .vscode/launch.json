{
    "version": "0.2.0",
    "configurations": [
        {
            "name": "Extension 1",
            "type": "extensionHost",
            "request": "launch",
            "runtimeExecutable": "${execPath}",
            "args": [
                "--extensionDevelopmentPath=${workspaceFolder}/out/extension"
            ],
            "outFiles": [
                "${workspaceFolder}/out/extension/**/*.js"
            ],
            "env": {
                "NODE_TLS_REJECT_UNAUTHORIZED": "0"
            }
        },
        {
            "name": "Extension 2",
            "type": "extensionHost",
            "request": "launch",
            "runtimeExecutable": "${execPath}",
            "args": [
                "--extensionDevelopmentPath=${workspaceFolder}/out/extension-temp"
            ],
            "outFiles": [
                "${workspaceFolder}/out/extension-temp/**/*.js"
            ],
            "env": {
                "NODE_TLS_REJECT_UNAUTHORIZED": "0"
            }
        }
    ],
    "compounds": [
        {
            "name": "Launch Both Extensions",
            "configurations": [
                "Extension 1",
                "Extension 2"
            ],
            "preLaunchTask": "execute",
        }
    ]
}