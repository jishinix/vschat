{
    "version": "2.0.0",
    "tasks": [
        {
            "label": "build-all",
            "type": "shell",
            "command": "npm run build",
            "problemMatcher": []
        },
        {
            "label": "Start Server",
            "type": "shell",
            "command": "node out/server/index.js",
            "isBackground": true,
            "problemMatcher": {
                "pattern": {
                    "regexp": "."
