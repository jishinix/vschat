{
    "version": "2.0.0",
    "tasks": [
        {
            "label": "stop-server",
            "type": "shell",
            "command": "docker compose down",
            "problemMatcher": [],
            "presentation": {
                "reveal": "silent",
                "close": true
            }
        },
        {
            "label": "build-all",
            "type": "shell",
            "command": "node build.js",
            "problemMatcher": [],
            "presentation": {
                "echo": true
            }
        },
        {
            "label": "Start Server",
            "type": "shell",
            "command": "docker compose up --build -d",
            "presentation": {
                "echo": true,
                "reveal": "always",
                "focus": false,
                "panel": "shared"
            },
            "problemMatcher": []
        },
        {
            "label": "copy-workspace",
            "type": "shell",
            "command": "node .vscode/task_clone.js",
            "problemMatcher": []
        },
        {
            "label": "execute",
            "dependsOrder": "sequence",
            "dependsOn": [
                "stop-server",
                "build-all",
                "copy-workspace",
                "Start Server"
            ],
            "problemMatcher": []
        }
    ]
}